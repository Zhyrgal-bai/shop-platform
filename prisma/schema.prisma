// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  telegramId  String   @unique
  name        String?
  /// Токен @BotFather — свой бот владельца (онбординг без BOT_TOKENS в env)
  botToken    String?  @unique

  orders      Order[]
  products    Product[]
  categories  Category[]
  settings    PaymentSettings[]
  ownedOrders Order[]  @relation("OrderOwner")
}

model Product {
  id               Int       @id @default(autoincrement())
  name             String
  price            Int
  createdAt        DateTime  @default(now())
  image            String
  images           String[]  @default([])
  description      String?
  categoryId       Int
  category         Category  @relation(fields: [categoryId], references: [id])
  isNew            Boolean   @default(false)
  isPopular        Boolean   @default(false)
  isSale           Boolean   @default(false)
  discountPercent  Int       @default(0) // 0–100, скидка от поля price
  sold             Int       @default(0)
  ownerId          Int
  owner            User      @relation(fields: [ownerId], references: [id])

  variants    Variant[]
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int?
  ownerId   Int
  owner     User       @relation(fields: [ownerId], references: [id])

  parent    Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToCategory")
  products  Product[]
}

model Variant {
  id        Int     @id @default(autoincrement())
  color     String
  colorHex  String?

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  sizes     Size[]
}

model Size {
  id        Int    @id @default(autoincrement())
  size      String
  stock     Int

  variant   Variant @relation(fields: [variantId], references: [id])
  variantId Int
}

model Order {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  ownerId   Int
  owner     User     @relation("OrderOwner", fields: [ownerId], references: [id])

  total     Int
  status    String   @default("NEW") // NEW | ACCEPTED | PAID_PENDING | CONFIRMED | SHIPPED | CANCELLED
  customerPhone String? // телефон из формы оформления
  tracking  String? // статус доставки / комментарий для клиента

  address String? // полный адрес доставки (текст)
  lat     Float? // широта (карта / геолокация)
  lng     Float? // долгота

  receiptUrl   String? // ссылка на фото или pdf
  receiptType  String? // "image" | "pdf"

  paymentMethod String @default("receipt") // "finik" | "receipt"
  paymentId     String? // id платежа Finik (и др.), когда подключено

  items     OrderItem[]
}

model OrderItem {
  id        Int   @id @default(autoincrement())

  productId Int
  name      String
  size      String
  color     String
  quantity  Int
  price     Int

  order     Order @relation(fields: [orderId], references: [id])
  orderId   Int
}

// Singleton id=1: реквизиты для оплаты (мини-апп + бот).
model PaymentSettings {
  id      Int    @id @default(autoincrement())
  ownerId Int
  owner   User   @relation(fields: [ownerId], references: [id])
  mbank  String?
  optima String?
  obank  String?
  card   String?
  qr     String?

  @@unique([ownerId])
}

model Promo {
  id       Int    @id @default(autoincrement())
  code     String @unique
  discount Int
  maxUses  Int
  used     Int    @default(0)
}