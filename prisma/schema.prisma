// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  telegramId  BigInt   @unique
  name        String?

  orders      Order[]
}

model Product {
  id               Int       @id @default(autoincrement())
  name             String
  price            Int
  image            String
  images           String[]  @default([])
  description      String?
  category         String    @default("")
  discountPercent  Int       @default(0) // 0–100, скидка от поля price
  sold             Int       @default(0)

  variants    Variant[]
}

model Variant {
  id        Int    @id @default(autoincrement())
  color     String

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  sizes     Size[]
}

model Size {
  id        Int    @id @default(autoincrement())
  size      String
  stock     Int

  variant   Variant @relation(fields: [variantId], references: [id])
  variantId Int
}

model Order {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int

  total     Int
  status    String   @default("NEW") // NEW | ACCEPTED | PAID_PENDING | CONFIRMED | SHIPPED | CANCELLED
  customerPhone String? // телефон из формы оформления
  tracking  String? // статус доставки / комментарий для клиента

  items     OrderItem[]
}

model OrderItem {
  id        Int   @id @default(autoincrement())

  productId Int
  name      String
  size      String
  color     String
  quantity  Int
  price     Int

  order     Order @relation(fields: [orderId], references: [id])
  orderId   Int
}

// Singleton id=1: реквизиты для оплаты (мини-апп + бот).
model PaymentSettings {
  id     Int     @id @default(1)
  mbank  String?
  optima String?
  obank  String?
  card   String?
  qr     String?
}

model Promo {
  id       Int    @id @default(autoincrement())
  code     String @unique
  discount Int
  maxUses  Int
  used     Int    @default(0)
}