# Copy to .env and fill in. See README deploy notes.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Public HTTPS URL of this API (no trailing slash), e.g. https://api.example.onrender.com
API_URL=
# Optional: full Telegram webhook URL. If empty, API_URL/telegram-webhook is used.
# TELEGRAM_WEBHOOK_URL=

# Telegram bots: several tokens for several stores (same order as BOT_OWNER_IDS / CHAT_IDS).
# Example: BOT_TOKENS=123:AAA,456:BBB
BOT_TOKENS=
# Single-bot legacy (if BOT_TOKENS is empty)
# BOT_TOKEN=

# DB user id владельца магазина i = i-й бот в BOT_TOKENS (для уведомлений и API бота).
BOT_OWNER_IDS=
# Чат админа i-го магазина (опционально, тот же порядок что и токены).
CHAT_IDS=

# Telegram user IDs allowed in admin (comma-separated)
ADMIN_IDS=
# Fallback: один чат для уведомлений, если CHAT_IDS не задан
CHAT_ID=

# Public URL of the Vercel (or other) mini app — use for links / BotFather web app
FRONT_URL=
